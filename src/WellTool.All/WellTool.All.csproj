<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net8.0;net6.0;netstandard2.1</TargetFrameworks>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<LangVersion>latest</LangVersion>
		<Version>1.0.1</Version>
		<PackageId>WellTool.All</PackageId>
		<PackageVersion>1.0.1</PackageVersion>
		<Title>WellTool All</Title>
		<Description>A comprehensive C# utility library</Description>
		<Authors>WellTool Team</Authors>
		<Company>WellTool</Company>
		<Copyright>© 2026 WellTool</Copyright>
		<PackageTags>utility;tools;helpers</PackageTags>
		<ProjectUrl>https://github.com/tozwei/WellTool</ProjectUrl>
		<IncludeBuildOutput>true</IncludeBuildOutput>
		<IncludeContentInPack>true</IncludeContentInPack>
		<TargetsForTfmSpecificBuildOutput>$(TargetsForTfmSpecificBuildOutput);CopyProjectReferencesToPackage</TargetsForTfmSpecificBuildOutput>
		<SuppressTfmSupportBuildWarnings>true</SuppressTfmSupportBuildWarnings>
	</PropertyGroup>



	<ItemGroup>
		<ProjectReference Include="..\WellTool.AI\WellTool.AI.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.Aop\WellTool.Aop.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.BloomFilter\WellTool.BloomFilter.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.Cache\WellTool.Cache.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.Captcha\WellTool.Captcha.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.Core\WellTool.Core.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.Cron\WellTool.Cron.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.Crypto\WellTool.Crypto.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.DB\WellTool.DB.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.Dfa\WellTool.Dfa.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.Extra\WellTool.Extra.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.Http\WellTool.Http.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.Json\WellTool.Json.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.Jwt\WellTool.Jwt.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.Log\WellTool.Log.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.Poi\WellTool.Poi.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.Script\WellTool.Script.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.Setting\WellTool.Setting.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.Socket\WellTool.Socket.csproj" PrivateAssets="all" />
		<ProjectReference Include="..\WellTool.System\WellTool.System.csproj" PrivateAssets="all" />
	</ItemGroup>

  <PropertyGroup>
    <RestoreSources>$(RestoreSources);$(MSBuildProjectDirectory)\..\nupkg</RestoreSources>
  </PropertyGroup>


   <Target Name="CopyProjectReferencesToPackage" DependsOnTargets="ResolveReferences">
		<ItemGroup>
			<!-- 筛选出所有标记为 PrivateAssets="all" 的项目引用 -->
			<BuildOutputInPackage Include="@(ReferenceCopyLocalPaths->WithMetadataValue('ReferenceSourceTarget', 'ProjectReference')->WithMetadataValue('PrivateAssets', 'All'))" />
		</ItemGroup>
	</Target>
</Project>