<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net8.0;net6.0;netstandard2.1</TargetFrameworks>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<LangVersion>latest</LangVersion>
		<Version>1.0.2</Version>
		<PackageId>WellTool.All</PackageId>
		<PackageVersion>1.0.2</PackageVersion>
		<Title>WellTool All</Title>
		<Description>All WellTool modules in one package</Description>
		<Authors>WellTool Team</Authors>
		<Company>WellTool</Company>
		<Copyright>© 2026 WellTool</Copyright>
		<PackageTags>welltool;all</PackageTags>
		<PackageProjectUrl>https://github.com/tozwei/WellTool</PackageProjectUrl>
		<RepositoryUrl>https://github.com/tozwei/WellTool</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
		<DebugType>portable</DebugType>
		<PublishRepositoryUrl>true</PublishRepositoryUrl>
		<EmbedUntrackedSources>true</EmbedUntrackedSources>
		<Deterministic>true</Deterministic>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\WellTool.AI\WellTool.AI.csproj" PrivateAssets="none" />
		<ProjectReference Include="..\WellTool.Aop\WellTool.Aop.csproj" PrivateAssets="none" />
		<ProjectReference Include="..\WellTool.BloomFilter\WellTool.BloomFilter.csproj" PrivateAssets="none" />
		<ProjectReference Include="..\WellTool.Bom\WellTool.Bom.csproj" PrivateAssets="none" />
		<ProjectReference Include="..\WellTool.Cache\WellTool.Cache.csproj" PrivateAssets="none" />
		<ProjectReference Include="..\WellTool.Captcha\WellTool.Captcha.csproj" PrivateAssets="none" />
		<ProjectReference Include="..\WellTool.Core\WellTool.Core.csproj" PrivateAssets="none" />
		<ProjectReference Include="..\WellTool.Cron\WellTool.Cron.csproj" PrivateAssets="none" />
		<ProjectReference Include="..\WellTool.Crypto\WellTool.Crypto.csproj" PrivateAssets="none" />
		<ProjectReference Include="..\WellTool.DB\WellTool.DB.csproj" PrivateAssets="none" />
		<ProjectReference Include="..\WellTool.Dfa\WellTool.Dfa.csproj" PrivateAssets="none" />
		<ProjectReference Include="..\WellTool.Extra\WellTool.Extra.csproj" PrivateAssets="none" />
		<ProjectReference Include="..\WellTool.Http\WellTool.Http.csproj" PrivateAssets="none" />
		<ProjectReference Include="..\WellTool.Json\WellTool.Json.csproj" PrivateAssets="none" />
		<ProjectReference Include="..\WellTool.Jwt\WellTool.Jwt.csproj" PrivateAssets="none" />
