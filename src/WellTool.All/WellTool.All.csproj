		<ProjectReference Include="..\WellTool.Socket\WellTool.Socket.csproj" PrivateAssets="none" />
		<ProjectReference Include="..\WellTool.System\WellTool.System.csproj" PrivateAssets="none" />
	</ItemGroup>

</Project>
